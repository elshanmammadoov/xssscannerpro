    def _test_single_payload(self, url, param_name, payload):
        body, _, _ = self.http.request(url, payload, method="GET")
        if body:
            findings = self.analyzer.find_reflection_context(body, payload)
            for finding in findings:
                if finding['exploitability'] >= 7:
                    return {
                        'status': 'vuln',
                        'type': 'Reflected XSS (URL Param)',
                        'param': param_name,
                        'payload': finding['payload'][:80],
                        'context': finding['context'],
                        'score': finding['exploitability'],
                        'reason': finding['reason'],
                        'url': url
                    }
        return {'status': 'safe'}

    def scan_url_params_concurrent(self, url):
        parsed = urllib.parse.urlparse(url)
        params = urllib.parse.parse_qs(parsed.query)
        
        if not params:
            self.log("URL-də parametr yoxdur, test parametrləri əlavə edilir...", 'warn')
            params = {'q': 'test', 'search': 'test', 'id': '1', 'page': '1'}
        
        tasks = []
        for param_name in params:
            for payload in PAYLOADS:
                tasks.append((param_name, payload))
        
        self.log(f"Ümumi {len(tasks)} sorğu göndərilir ({self.threads} paralel thread)...", 'info')
        print()
        
        completed = 0
        with ThreadPoolExecutor(max_workers=self.threads) as executor:
            future_to_task = {
                executor.submit(self._test_single_payload, url, p_name, pay): (p_name, pay)
                for p_name, pay in tasks
            }
            
            for future in as_completed(future_to_task):
                self.total_tests += 1
                completed += 1
                try:
                    res = future.result()
                    if res['status'] == 'vuln':
                        self.vulnerabilities.append(res)
                        print()
                        self.log(f"VULNERABLE! Param='{res['param']}' | Context={res['context']} | Score={res['score']}/10", 'vuln')
                        self.log(f"Payload: {res['payload'][:70]}", 'vuln')
                        self.log(f"Səbəb: {res['reason']}", 'vuln')
                    else:
                        self.false_positives += 1
                except Exception:
                    pass
                
                sys.stdout.write(f"\r{C.C}İrəliləyiş: {completed}/{len(tasks)} tamamlandı{C.RST}     ")
                sys.stdout.flush()
        print()

    def scan_forms(self, url):
        self.log("Formlar aşkar edilir...", 'info')
        body, status, _ = self.http.request(url)
        if not body:
            self.log("Sayt yüklənmədi, form skanı keçilir.", 'warn')
            return
        
        forms = re.findall(
            r'<form[^>]*action=["\']?([^"\'\s>]*)["\']?[^>]*method=["\']?(\w+)["\']?[^>]*>(.*?)</form>',
            body, re.DOTALL | re.IGNORECASE
        )
        
        if not forms:
            self.log("Saytda form tapılmadı.", 'warn')
            return
        
        self.log(f"{len(forms)} form tapıldı!", 'ok')
        print()
        
        for idx, (action, method, form_body) in enumerate(forms, 1):
            inputs = re.findall(r'<input[^>]*name=["\']?([^"\'\s>]*)', form_body, re.IGNORECASE)
            inputs += re.findall(r'<textarea[^>]*name=["\']?([^"\'\s>]*)', form_body, re.IGNORECASE)
            
            if not inputs:
                continue
            
            test_inputs = inputs[:3]
            for input_name in test_inputs:
                for payload in PAYLOADS[:15]:
                    self.total_tests += 1
                    post_data = {inp: payload for inp in test_inputs}
                    data_encoded = urllib.parse.urlencode(post_data)
                    body_resp, _, _ = self.http.request(url, payload, method="POST", data=data_encoded)
                    
                    if body_resp:
                        findings = self.analyzer.find_reflection_context(body_resp, payload)
                        for finding in findings:
                            if finding['exploitability'] >= 7:
                                self.vulnerabilities.append({
                                    'type': f'Reflected XSS (Form {method.upper()})',
                                    'param': input_name,
                                    'payload': finding['payload'][:80],
                                    'context': finding['context'],
                                    'score': finding['exploitability'],
                                    'reason': finding['reason'],
                                    'url': url
                                })
                                print()
                                self.log(f"VULNERABLE! Form={method.upper()} | Input='{input_name}' | Context={finding['context']}", 'vuln')
                                break
                            else:
                                self.false_positives += 1
    
    def scan_headers(self, url):
        header_payloads = [
            ('User-Agent', '<script>alert(1)</script>'),
            ('Referer', '<script>alert(1)</script>'),
            ('X-Forwarded-For', '<img src=x onerror=alert(1)>'),
            ('X-Originating-IP', '<svg onload=alert(1)>'),
        ]
        
        for header_name, payload in header_payloads:
            self.total_tests += 1
            try:
                headers = {'User-Agent': 'Mozilla/5.0', header_name: payload}
                req = urllib.request.Request(url, headers=headers)
                with urllib.request.urlopen(req, timeout=10, context=self.http.ctx) as resp:
                    body = resp.read().decode('utf-8', errors='ignore')
                    if payload in body:
                        self.log(f"VULNERABLE! Header '{header_name}' reflects payload!", 'vuln')
                        self.vulnerabilities.append({

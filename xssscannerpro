                f.write(f"Vulnerabilities Found: {len(self.vulnerabilities)}\n\n")
                
                for idx, v in enumerate(self.vulnerabilities, 1):
                    f.write(f"[{idx}] Type: {v['type']}\n")
                    f.write(f"    Parameter: {v['param']}\n")
                    f.write(f"    Context: {v['context']}\n")
                    f.write(f"    Score: {v['score']}/10\n")
                    f.write(f"    Payload: {v['payload']}\n\n")
            print(f"{C.G}[+] Hesabat uğurla yadda saxlandı: {self.output_file}{C.RST}\n")
        except Exception as e:
            print(f"{C.R}[!] Fayla yazmaq mümkün olmadı: {e}{C.RST}")



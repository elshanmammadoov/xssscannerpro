# ─── SECURITY ANALYZER ────────────────────────────────────
class SecurityAnalyzer:
    @staticmethod
    def analyze_xss(response_text, payload):
        findings = []
        variants = [
            ('raw', payload),
            ('url_encoded', urllib.parse.quote(payload, safe='')),
            ('html_encoded', html.escape(payload)),
        ]
        
        for variant_name, variant_payload in variants:
            idx = response_text.find(variant_payload)
            if idx == -1:
                continue
            
            before = response_text[max(0, idx-150):idx]
            script_matches = list(re.finditer(r'<script[^>]*>(.*?)</script>', response_text, re.DOTALL | re.IGNORECASE))
            in_script = any(m.start() <= idx <= m.end() for m in script_matches)
            
            if in_script:
                findings.append({'context': 'Script Tag', 'score': 9, 'reason': 'Payload inside <script> tag — executable'})
            else:
                last_tag_open = before.rfind('<')
                last_tag_close = before.rfind('>')
                if last_tag_close > last_tag_open:
                    findings.append({'context': 'HTML Body', 'score': 8, 'reason': 'Payload reflected in HTML body'})
        return findings

    @staticmethod
    def analyze_sqli(response_text):
        text_lower = response_text.lower()
        findings = []
        for err_sig, err_desc in SQLI_ERRORS:
            if err_sig in text_lower:
                findings.append({
                    'type': 'SQL Injection (Error-Based)',
                    'score': 9,
                    'reason': f"Database error detected in response: {err_desc}"
                })
                break
        return findings

# ─── ADVANCED HTTP ENGINE ─────────────────────────────────
class HTTPEngine:
    def __init__(self):
        self.ctx = ssl.create_default_context()
        self.ctx.check_hostname = False
        self.ctx.verify_mode = ssl.CERT_NONE
    
    def request(self, url, payload="", method="GET", post_data=None):
        try:
            headers = {
                'User-Agent': random.choice(USER_AGENTS),
                'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
                'Accept-Language': 'en-US,en;q=0.5',
                'Connection': 'close',
            }
            
            test_url = url
            encoded_data = None

            if method == "GET":
                if payload:
                    parsed = urllib.parse.urlparse(url)
                    params = urllib.parse.parse_qs(parsed.query)
                    if params:
                        for key in params:
                            params[key] = [payload]
                        new_query = urllib.parse.urlencode(params, doseq=True)
                        test_url = urllib.parse.urlunparse(parsed._replace(query=new_query))
                    else:
                        sep = '&' if '?' in url else '?'
                        test_url = f"{url}{sep}test={urllib.parse.quote(payload, safe='')}"
            elif method == "POST":
                if post_data:
                    parsed_data = urllib.parse.parse_qs(post_data)
                    for key in parsed_data:
                        parsed_data[key] = [payload]
                    encoded_data = urllib.parse.urlencode(parsed_data, doseq=True).encode('utf-8')
                    headers['Content-Type'] = 'application/x-www-form-urlencoded'

            req = urllib.request.Request(
                test_url, 
                data=encoded_data if method == "POST" else None, 
                headers=headers, 
                method=method
            )
            
            with urllib.request.urlopen(req, timeout=12, context=self.ctx) as resp:
                body = resp.read().decode('utf-8', errors='ignore')
                return body, resp.status
        except urllib.error.HTTPError as e:
            body = e.read().decode('utf-8', errors='ignore') if e.fp else ""
            return body, e.code
        except Exception:
            return None, None

# ─── MAIN SCANNER ─────────────────────────────────────────
class XSSScannerPro:
    def __init__(self, threads=15, method="GET", post_data=None, output=None):
        self.http = HTTPEngine()
        self.analyzer = SecurityAnalyzer()
        self.vulnerabilities = []
        self.threads = threads
        self.method = method.upper()
        self.post_data = post_data
        self.output = output
    
    def log(self, msg, level='info'):
        symbols = {'info': '[i]', 'vuln': '[!]', 'ok': '[+]', 'warn': '[?]', 'scan': '[*]'}
        colors = {'info': C.B, 'vuln': C.R+C.BOLD, 'ok': C.G, 'warn': C.Y, 'scan': C.C}
        print(f"{colors.get(level, C.W)}{symbols.get(level, '[*]')} {msg}{C.RST}")
    
    def validate_url(self, url):
        if not url.startswith(('http://', 'https://')):
            url = 'https://' + url
        parsed = urllib.parse.urlparse(url)
        return url if parsed.netloc and '.' in parsed.netloc else None
    
    def scan_target(self, target_url):
        target_url = self.validate_url(target_url)
        if not target_url:
            self.log("Yanlış URL formatı!", 'vuln')
            return
        
        self.log(f"Hədəf: {target_url} [{self.method}]", 'scan')
        self.log("Hədəfə qoşulma və WAF yoxlanılır...", 'info')
        baseline_body, status = self.http.request(target_url, method=self.method, post_data=self.post_data)
        
        if baseline_body is None:
            self.log("Qoşulma uğursuz oldu və ya hədəf blokladı!", 'vuln')
            return
        
        self.log(f"Hədəf aktiv — HTTP {status}", 'ok')
        print()

        # Phase 1: XSS Scan
        self.log("MƏRHƏLƏ 1: XSS Skaneri (Paralel & WAF Bypass)", 'scan')
        self.run_concurrent_tests(target_url, XSS_PAYLOADS, 'XSS')

        # Phase 2: SQLi Scan
        print()
        self.log("MƏRHƏLƏ 2: SQL Injection Skaneri (Error-Based)", 'scan')
        self.run_concurrent_tests(target_url, SQLI_PAYLOADS, 'SQLI')

        self.print_report(target_url)

    def _test_payload(self, url, param_name, payload, scan_type):
        body, status = self.http.request(url, payload, method=self.method, post_data=self.post_data)
        if not body:
            return {'status': 'safe'}
            
        if scan_type == 'XSS':
            findings = self.analyzer.analyze_xss(body, payload)
            for f in findings:
                if f['score'] >= 7:
                    return {'status': 'vuln', 'type': 'Reflected XSS', 'param': param_name, 'payload': payload, 'reason': f['reason']}
        elif scan_type == 'SQLI':
            findings = self.analyzer.analyze_sqli(body)
            for f in findings:
                return {'status': 'vuln', 'type': f['type'], 'param': param_name, 'payload': payload, 'reason': f['reason']}
        return {'status': 'safe'}

    def run_concurrent_tests(self, url, payloads, scan_type):
        if self.method == "GET":
            parsed = urllib.parse.urlparse(url)
            params = urllib.parse.parse_qs(parsed.query)
            if not params:
                params = {'id': '1', 'search': 'test', 'q': 'test'}
        else:
            params = urllib.parse.parse_qs(self.post_data) if self.post_data else {'username': 'test'}
            
        tasks = [(p_name, pay) for p_name in params for pay in payloads]
        completed = 0
        total = len(tasks)
        bar_length = 30
        
        with ThreadPoolExecutor(max_workers=self.threads) as executor:
            future_to_task = {
                executor.submit(self._test_payload, url, p_name, pay, scan_type): (p_name, pay)
                for p_name, pay in tasks
            }
            
            for future in as_completed(future_to_task):
                completed += 1
                try:
                    res = future.result()
                    if res['status'] == 'vuln':
                        self.vulnerabilities.append(res)
                        print(f"\n{C.R}[!]{C.RST} ZƏİFLİK TAPILDI! [{res['type']}] Param='{res['param']}' | Səbəb: {res['reason']}")
                except Exception:
                    pass
                
                percent = int((completed / total) * 100) if total > 0 else 100
                filled = int(bar_length * completed // total) if total > 0 else bar_length
                bar = '█' * filled + '-' * (bar_length - filled)
                
                sys.stdout.write(f"\r{C.C}[{bar}] {percent}% ({completed}/{total}){C.RST}")
                sys.stdout.flush()
        print()

    def print_report(self, target_url):
        print(f"\n{C.BOLD}{'═' * 64}{C.RST}")
        print(f"{C.BOLD}  YEKUN HESABAT (v6.1 PRO){C.RST}")
        print(f"{C.BOLD}{'═' * 64}{C.RST}\n")
        print(f"  Hədəf URL     : {C.Y}{target_url}{C.RST}")
        print(f"  Tapılan Zəiflik: {C.R if self.vulnerabilities else C.G}{len(self.vulnerabilities)}{C.RST}\n")
        
        for idx, v in enumerate(self.vulnerabilities, 1):
            print(f"  {C.R}#{idx} Növ: {v['type']} | Parametr: {v['param']} | Payload: {v['payload']}{C.RST}")

        if self.output and self.vulnerabilities:
            try:
                with open(self.output, 'w', encoding='utf-8') as f:
                    json.dump(self.vulnerabilities, f, indent=4, ensure_ascii=False)
                self.log(f"Hesabat uğurla yadda saxlandı: {self.output}", 'ok')
            except Exception as e:
                self.log(f"Fayla yazılarkən xəta: {e}", 'warn')

